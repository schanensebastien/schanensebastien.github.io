# Copy this file to functions/.env and fill in your values.
# These are NON-secret config values (read at deploy time).
# The two real secrets are set separately with `firebase functions:secrets:set`
# (GMAIL_CLIENT_SECRET and GMAIL_REFRESH_TOKEN) — never put them here.

# The Gmail address that SENDS the mail (must own the OAuth credentials):
GMAIL_USER=you@gmail.com

# OAuth2 client ID from Google Cloud Console (Desktop or Web app):
GMAIL_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com

# Where notifications/contact mails are delivered (defaults to GMAIL_USER if empty):
MAIL_TO=schanen.sebastien@outlook.de

# Comma-separated list of allowed browser origins (CORS):
ALLOWED_ORIGINS=https://schanensebastien.com,https://www.schanensebastien.com,http://localhost:8080,http://localhost:8123
